# Copy this file to .env and fill in real values. .env is gitignored.

# --- Google Maps Platform (single key, billing must be enabled) ---
# Required APIs to enable on this key:
#   - Places API (new), Places API (legacy nearby + details)
#   - Solar API
#   - Maps Static API
# Restrict the key to your local machine's IP during development.
GOOGLE_MAPS_API_KEY=

# --- Anthropic ---
# Used by the Claude vision fallback when Solar API has no coverage.
ANTHROPIC_API_KEY=

# --- App config ---
# Set to "mock" to run the pipeline with fixture data and zero external calls.
# Useful before you have a Google key, or for offline development.
# Set to "live" once you have a Google key with billing enabled.
APP_MODE=mock

# Default search radius in miles (the UI can override this per request)
DEFAULT_RADIUS_MILES=15

# Maximum candidates returned per search
MAX_RESULTS=100

# SQLite cache location (inside the backend container)
CACHE_DB_PATH=/app/cache.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# CORS: the frontend dev origin
FRONTEND_ORIGIN=http://localhost:5173
